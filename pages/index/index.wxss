/* pages/index/index.wxss — 极简 AI 首页，统一白/浅蓝/浅绿健康风格 */

/* 配额提示条 */
.quota-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #FFF7F0, #FFF2F0);
  border: 1rpx solid #FFE0D0;
  border-radius: 100rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 20rpx;
}
.quota-bar-text {
  font-size: 24rpx;
  color: #FF4D4F;
  font-weight: 600;
}
.quota-bar-btn {
  font-size: 24rpx;
  color: #FF7A45;
  font-weight: 700;
}

/* 配额剩余提示条 */
.quota-remaining-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #FFFDF7;
  border: 1rpx solid #FFEFD5;
  border-radius: 100rpx;
  padding: 12rpx 20rpx;
  margin-bottom: 20rpx;
}
.qr-text {
  font-size: 22rpx;
  color: #8A6D00;
  font-weight: 600;
  white-space: nowrap;
}
.qr-progress {
  flex: 1;
  height: 8rpx;
  background: #FFE8B5;
  border-radius: 100rpx;
  overflow: hidden;
}
.qr-fill {
  height: 100%;
  background: linear-gradient(90deg, #FFD700, #FFA500);
  border-radius: 100rpx;
}
.qr-link {
  font-size: 22rpx;
  color: #FF7A45;
  font-weight: 700;
  white-space: nowrap;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 0 28rpx 40rpx;
  background: linear-gradient(180deg, #F2FAFF 0%, #F7FBF8 46%, #FFFFFF 100%);
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* ① 顶部欢迎条 */
.top-card {
  display: flex; align-items: center; justify-content: space-between;
  background: #FFFFFF; border-radius: 28rpx; padding: 28rpx;
  margin-bottom: 22rpx; box-shadow: 0 8rpx 28rpx rgba(36,64,112,.06);
}
.hello { display: block; font-size: 40rpx; line-height: 52rpx; font-weight: 800; color: #162033; }
.tag-row { display: flex; align-items: center; gap: 12rpx; margin-top: 12rpx; }
.stage-tag, .vip-tag, .free-tag { display: inline-flex; align-items: center; height: 38rpx; padding: 0 18rpx; border-radius: 999rpx; font-size: 22rpx; font-weight: 700; }
.stage-tag { background: #EAF3FD; color: #2F80D1; }
.vip-tag { background: linear-gradient(135deg, #FFE7A3, #F6B84A); color: #7A4A00; }
.free-tag { background: #F0F2F5; color: #8A94A6; }
.top-right { display: flex; align-items: center; color: #8A94A6; }
.profile-text { font-size: 24rpx; }
.profile-arrow { font-size: 40rpx; margin-left: 4rpx; line-height: 40rpx; }

/* ② AI 对话主区 */
.ai-panel {
  background: transparent;
  border-radius: 0;
  padding: 0;
  margin-bottom: 0;
  box-shadow: none;
  border: 0;
  transition: all .2s ease;
}
.ai-panel-expanded { box-shadow: none; border-color: transparent; }
.ai-fullscreen {
  position: fixed; left: 0; right: 0; top: 0; bottom: 0; z-index: 99;
  margin: 0; padding: 40rpx 28rpx 28rpx; border-radius: 0; box-sizing: border-box;
  display: flex; flex-direction: column; background: #FFFFFF;
}
.ai-head { display: flex; align-items: flex-start; margin-bottom: 20rpx; }
.hero { text-align: center; margin-bottom: 44rpx; }
.hero-title { display: block; font-size: 46rpx; line-height: 62rpx; font-weight: 800; color: #2C3E50; letter-spacing: -1rpx; }
.hero-subtitle { display: block; margin-top: 12rpx; font-size: 26rpx; line-height: 38rpx; color: #7F8C8D; }
.ai-avatar {
  width: 76rpx; height: 76rpx; border-radius: 24rpx;
  background: linear-gradient(135deg, #4A90D9, #6BA9EF); color: #FFFFFF;
  display: flex; align-items: center; justify-content: center;
  font-size: 34rpx; font-weight: 900; flex-shrink: 0;
  box-shadow: 0 8rpx 18rpx rgba(74,144,217,.28);
}
.ai-info { flex: 1; margin-left: 18rpx; }
.ai-title-row { display: flex; align-items: center; }
.ai-title { font-size: 32rpx; font-weight: 800; color: #162033; }
.online-dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: #35C56A; margin-left: 14rpx; }
.offline-dot { background: #BDC3C7; }
.online-text { margin-left: 8rpx; font-size: 22rpx; color: #35A85F; font-weight: 700; }
.ai-desc { display: block; margin-top: 12rpx; font-size: 26rpx; color: #5F6D83; line-height: 1.55; }
.ai-actions { display: flex; gap: 10rpx; flex-shrink: 0; }
.collapse-btn, .clear-btn { font-size: 22rpx; color: #4A90D9; padding: 6rpx 16rpx; border-radius: 100rpx; border: 1rpx solid #D6E9FC; flex-shrink: 0; }
.clear-btn { color: #8A94A6; border-color: #E4E8F0; }

/* 对话流区域 */
.chat-box {
  width: 100%;
  max-height: 460rpx;
  box-sizing: border-box;
  background: #F8FAFE;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}
.ai-fullscreen .chat-box {
  flex: 1;
  width: 100%;
  max-height: none;
  min-height: 0;
  box-sizing: border-box;
}
.empty-chat { padding: 24rpx 0; text-align: center; }
.empty-chat-text { font-size: 24rpx; color: #A7B1C2; }
.msg-row { display: flex; margin-bottom: 20rpx; }
.msg-user { justify-content: flex-end; }
.msg-ai { justify-content: flex-start; }
.msg-bubble { max-width: 82%; padding: 16rpx 22rpx; border-radius: 18rpx; font-size: 30rpx; line-height: 1.65; }
.user-bubble { background: #4A90D9; color: #fff; border-radius: 18rpx 4rpx 18rpx 18rpx; }
.ai-bubble { background: #fff; color: #162033; border-radius: 4rpx 18rpx 18rpx 18rpx; }
.cursor { animation: blink 1s infinite; }
@keyframes blink { 0%,100%{opacity:1}50%{opacity:0} }
.loading-dots { display: flex; gap: 8rpx; align-items: center; padding: 8rpx 0; }
.loading-dots .dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: #BDC3C7; animation: dotPulse 1.2s infinite; }
.loading-dots .dot:nth-child(2) { animation-delay: .2s; }
.loading-dots .dot:nth-child(3) { animation-delay: .4s; }
@keyframes dotPulse { 0%,60%,100%{opacity:.3}30%{opacity:1} }

/* 卡片通用 */
.simple-card { margin-top: 12rpx; }
.card-tappable:active { transform: scale(.98); opacity: .9; }
.card-title-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12rpx; }
.card-title { font-size: 27rpx; font-weight: 800; color: #162033; }
.card-date { font-size: 21rpx; color: #8A94A6; }
.card-footer { margin-top: 12rpx; padding-top: 10rpx; border-top: 1rpx solid #EEF1F6; font-size: 22rpx; color: #4A90D9; }
.card-tip { margin-top: 10rpx; background: #F8FAFE; border-radius: 12rpx; padding: 10rpx 12rpx; font-size: 23rpx; color: #5F6D83; }
.safe-badge { font-size: 20rpx; padding: 4rpx 10rpx; border-radius: 999rpx; }
.safe-safe { background: #F0FFF0; color: #35A85F; }
.safe-warning, .safe-caution { background: #FFF7E6; color: #FA8C16; }
.safe-danger { background: #FFF2F0; color: #FF4D4F; }

/* 报告卡 */
.home-report-card { background: #F0F7FF; border-left: 6rpx solid #4A90D9; border-radius: 18rpx; padding: 18rpx; }
.report-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10rpx; }
.report-item { background: #fff; border-radius: 12rpx; padding: 12rpx; }
.report-label { display: block; font-size: 21rpx; color: #66758C; }
.report-value { display: block; font-size: 25rpx; font-weight: 800; color: #162033; margin-top: 2rpx; }
.report-eval { display: inline-block; margin-top: 4rpx; font-size: 20rpx; }
.eval-ok { color: #35A85F; }
.eval-warn { color: #FF4D4F; }

/* 今日营养卡 */
.home-nutrition-card { background: #FFFDF7; border-left: 6rpx solid #FAAD14; border-radius: 18rpx; padding: 18rpx; }
.nutrition-topline { display: flex; gap: 30rpx; margin-bottom: 12rpx; }
.big-num { font-size: 34rpx; font-weight: 900; color: #4A90D9; }
.protein-num { color: #52C41A; }
.unit-text { font-size: 21rpx; color: #8A94A6; margin-left: 4rpx; }
.usage-row { display: flex; align-items: center; gap: 10rpx; margin: 8rpx 0; }
.usage-name { width: 34rpx; font-size: 22rpx; color: #66758C; }
.usage-track { flex: 1; height: 10rpx; background: #EEF1F6; border-radius: 999rpx; overflow: hidden; }
.usage-fill { height: 100%; background: linear-gradient(90deg, #4A90D9, #6BA9EF); border-radius: 999rpx; }
.usage-value { width: 58rpx; text-align: right; font-size: 21rpx; color: #66758C; }

/* 食物/菜谱 */
.home-food-card { background: #F8FFF8; border-left: 6rpx solid #52C41A; border-radius: 18rpx; padding: 18rpx; }
.nutrient-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8rpx; }
.nutrient-grid > view { background: #fff; border-radius: 12rpx; padding: 10rpx 4rpx; text-align: center; }
.nutrient-num { display: block; font-size: 24rpx; font-weight: 800; color: #162033; }
.nutrient-label { font-size: 19rpx; color: #8A94A6; }

/* 食谱卡片：对齐旧“问小光”卡片效果 */
.card-recipe:active { opacity: 0.85; transform: scale(0.98); }
.card-recipe {
  background: #FFFFFF; border-radius: 20rpx; padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(74,144,217,0.15);
  border-left: 8rpx solid #4A90D9; max-width: 100%;
}
.card-recipe-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx; gap: 16rpx; }
.card-recipe-name { font-size: 30rpx; font-weight: 700; color: #2C3E50; flex: 1; }
.card-nutrients { display: flex; gap: 16rpx; flex-wrap: wrap; margin-bottom: 20rpx; }
.nutrient-item { display: flex; align-items: center; gap: 8rpx; background: #F5F7FA; border-radius: 100rpx; padding: 8rpx 20rpx; }
.nutrient-name { font-size: 22rpx; color: #7F8C8D; }
.nutrient-val { font-size: 24rpx; font-weight: 600; color: #2C3E50; }
.nutrient-eval { font-size: 20rpx; font-weight: 600; }
.eval-safe { color: #52C41A; }
.eval-warning { color: #FAAD14; }
.eval-danger { color: #FF4D4F; }
.card-tip-row { display: flex; align-items: flex-start; gap: 8rpx; margin-bottom: 16rpx; }
.card-tip-icon { font-size: 24rpx; flex-shrink: 0; }
.card-tip-text { font-size: 24rpx; color: #7F8C8D; line-height: 1.6; }
.card-action-row { border-top: 1rpx solid #F0F4F8; padding-top: 16rpx; text-align: right; }
.card-action-text { font-size: 24rpx; color: #4A90D9; font-weight: 600; }

/* 商品/提醒/技巧/建议 */
.home-product-card { background: #FFF7F0; border-left: 6rpx solid #FF7A45; border-radius: 18rpx; padding: 18rpx; }
.product-main { display: flex; gap: 14rpx; }
.product-img { width: 110rpx; height: 110rpx; border-radius: 14rpx; background: #F0F2F5; }
.product-info { flex: 1; display: flex; flex-direction: column; }
.product-name { font-size: 26rpx; font-weight: 800; color: #162033; }
.product-desc { font-size: 22rpx; color: #66758C; margin: 4rpx 0; }
.product-price { font-size: 30rpx; font-weight: 900; color: #FF4D4F; }
.warning-card { background: #FFF2F0; padding: 14rpx; border-radius: 14rpx; border-left: 6rpx solid #FF4D4F; }
.warning-title { font-size: 26rpx; font-weight: 700; color: #FF4D4F; display: block; }
.warning-content { font-size: 24rpx; color: #162033; display: block; margin-top: 4rpx; }
.tip-card { background: #F0F7FF; padding: 14rpx; border-radius: 14rpx; border-left: 6rpx solid #4A90D9; }
.tip-title { font-size: 26rpx; font-weight: 700; color: #4A90D9; display: block; }
.tip-content { font-size: 24rpx; color: #162033; display: block; margin-top: 4rpx; }
.suggest-card { margin-top: 8rpx; }
.suggest-item { background: #F0F7FF; padding: 12rpx 16rpx; border-radius: 12rpx; margin-bottom: 6rpx; font-size: 24rpx; color: #4A90D9; }

/* DeepSeek / ChatGPT 式极简输入框 */
.ask-box {
  display: flex; align-items: center; min-height: 108rpx;
  background: #FFFFFF; border-radius: 34rpx; padding: 0 18rpx 0 32rpx;
  box-shadow: 0 18rpx 48rpx rgba(74,144,217,.13), inset 0 0 0 1rpx #DDEEFF;
}
.ai-fullscreen .ask-box { min-height: 92rpx; border-radius: 28rpx; box-shadow: inset 0 0 0 1rpx #DDEEFF, 0 6rpx 18rpx rgba(74,144,217,.08); }
.ask-input { flex: 1; height: 108rpx; font-size: 30rpx; color: #2C3E50; }
.ai-fullscreen .ask-input { height: 92rpx; font-size: 28rpx; }
.ask-placeholder { color: #A0AEC0; }
.send-circle { width: 68rpx; height: 68rpx; border-radius: 50%; background: linear-gradient(135deg, #4A90D9, #52C41A); display: flex; align-items: center; justify-content: center; flex-shrink: 0; box-shadow: 0 8rpx 18rpx rgba(74,144,217,.22); }
.ai-fullscreen .send-circle { width: 64rpx; height: 64rpx; }
.send-arrow { font-size: 34rpx; color: #fff; font-weight: 900; }
.chip-row { display: flex; gap: 14rpx; margin-top: 18rpx; }
.chip { flex: 1; height: 58rpx; border-radius: 999rpx; background: #EEF6FF; color: #2F80D1; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: 700; }
.home-entry-row {
  display: flex;
  justify-content: center;
  margin-top: 22rpx;
}
.home-entry {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,.82);
  border: 1rpx solid #DDEEFF;
  box-shadow: 0 8rpx 22rpx rgba(74,144,217,.08);
}
.home-entry:active { opacity: .75; transform: scale(.98); }
.home-entry-icon { font-size: 28rpx; }
.home-entry-text { font-size: 24rpx; font-weight: 700; color: #4A90D9; }
.recipe-tab-guide {
  position: fixed;
  /* 4 个 Tab 的第 2 项中心点是屏幕宽度的 37.5%，不是页面正中 50% */
  left: 37.5%;
  bottom: 28rpx;
  z-index: 20;
  display: flex;
  flex-direction: column;
  align-items: center;
  pointer-events: auto;
  transform: translateX(-50%);
}
.guide-bubble {
  width: 300rpx;
  padding: 14rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,.96);
  border: 1rpx solid #DDEEFF;
  box-shadow: 0 8rpx 24rpx rgba(74,144,217,.14);
  text-align: center;
  box-sizing: border-box;
}
.guide-title {
  display: block;
  font-size: 24rpx;
  font-weight: 800;
  color: #2C3E50;
}
.guide-desc {
  display: block;
  margin-top: 2rpx;
  font-size: 21rpx;
  color: #4A90D9;
}
.guide-arrow-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: guideBounce 1.15s ease-in-out infinite;
}
.guide-line {
  width: 2rpx;
  height: 18rpx;
  background: linear-gradient(180deg, #9ED2FF, #4A90D9);
}
.guide-arrow {
  margin-top: -6rpx;
  font-size: 36rpx;
  line-height: 36rpx;
  color: #4A90D9;
  font-weight: 900;
}
@keyframes guideBounce {
  0%,100% { transform: translateY(0); opacity: .9; }
  50% { transform: translateY(8rpx); opacity: 1; }
}
.subtle-profile { margin-top: 30rpx; text-align: center; font-size: 23rpx; color: #7F8C8D; }

/* 示例问题样式 */
.quick-examples {
  margin-top: 28rpx;
}
.example-title {
  font-size: 26rpx;
  color: #8A94A6;
  margin-bottom: 16rpx;
  text-align: center;
  font-weight: 600;
}
.example-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.example-item {
  background: #FFFFFF;
  border-radius: 18rpx;
  padding: 18rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(74,144,217,.1);
  border: 1rpx solid #DDEEFF;
  font-size: 26rpx;
  color: #4A90D9;
  font-weight: 600;
}
.example-item:active {
  opacity: 0.8;
  transform: scale(0.99);
}

/* ③ 今日摄入 */
.intake-section { background: #FFFFFF; border-radius: 28rpx; padding: 26rpx 24rpx 22rpx; margin-bottom: 24rpx; box-shadow: 0 8rpx 24rpx rgba(36,64,112,.06); }
.section-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18rpx; }
.section-title { font-size: 30rpx; font-weight: 800; color: #162033; }
.section-more { font-size: 24rpx; color: #4A90D9; font-weight: 500; }
.intake-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14rpx; }
.intake-card { padding: 20rpx 22rpx; border-radius: 20rpx; background: #F9FAFB; }
.intake-label { font-size: 24rpx; color: #66758C; font-weight: 600; display: block; }
.intake-value { font-size: 42rpx; font-weight: 900; color: #162033; display: block; margin-top: 4rpx; }
.intake-unit { font-size: 22rpx; color: #8A94A6; margin-left: 4rpx; }
.calorie-card .intake-value { color: #4A90D9; }
.protein-card .intake-value { color: #52C41A; }
.k-card .intake-value { color: #FA8C16; }
.p-card .intake-value { color: #7C3AED; }
.mini-bar { height: 10rpx; background: #EEF1F6; border-radius: 999rpx; margin-top: 14rpx; overflow: hidden; }
.mini-fill { height: 100%; border-radius: 999rpx; }
.k-fill { background: linear-gradient(90deg, #FFCB67, #FF8A3D); }
.p-fill { background: linear-gradient(90deg, #BDA5FF, #7F56D9); }

/* ④ 常用功能宫格 */
.func-section { background: #FFFFFF; border-radius: 28rpx; padding: 26rpx 20rpx 22rpx; box-shadow: 0 8rpx 24rpx rgba(36,64,112,.06); }
.func-grid { display: grid; grid-template-columns: repeat(4, 1fr); }
.func-item { display: flex; flex-direction: column; align-items: center; padding: 10rpx 0; }
.func-icon-wrap { width: 80rpx; height: 80rpx; border-radius: 24rpx; display: flex; align-items: center; justify-content: center; margin-bottom: 10rpx; }
.report-bg { background: #EAF3FD; }
.record-bg { background: #FFF7E6; }
.food-bg { background: #F0FFF0; }
.recipe-bg { background: #FFF0F0; }
.func-icon { font-size: 38rpx; }
.func-label { font-size: 24rpx; color: #162033; font-weight: 700; }
.func-desc { font-size: 20rpx; color: #8A94A6; margin-top: 4rpx; }
