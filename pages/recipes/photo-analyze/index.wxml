<!-- pages/recipes/photo-analyze/index.wxml - 拍照识别分析页 -->
<view class="photo-wrap">

  <!-- ════════════════ 自定义导航栏 ════════════════ -->
  <view class="nav-bar" style="padding-top:{{statusBarHeight}}px">
    <view class="nav-content">
      <view class="nav-back" bindtap="goBack">
        <text class="nav-back-icon">‹</text>
      </view>
      <text class="nav-title">图片分析</text>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <!-- ════════════════ 图片预览 + 识别结果 ════════════════ -->
  <view class="preview-section">
    <!-- 拍摄的图片 -->
    <view class="photo-frame">
      <image
        class="photo-img"
        src="{{photoSrc}}"
        mode="aspectFill"
        wx:if="{{photoSrc}}"
      />
      <view class="photo-badge" wx:if="{{!analyzing && !result}}">
        <text class="badge-text">已拍摄</text>
      </view>
    </view>

    <!-- AI 识别结果 -->
    <view class="recognize-result" wx:if="{{dishName && !result}}">
      <view class="recognize-label">
        <text>AI 识别结果</text>
        <text class="recognize-edit" bindtap="editDishName">✏️ 修改</text>
      </view>
      <view class="recognize-name">{{dishName}}</view>
      <view class="recognize-hint">请确认图片类型，获取针对性分析</view>
    </view>

    <!-- 编辑识别结果弹窗 -->
    <view class="edit-modal-mask" wx:if="{{showEditModal}}" bindtap="closeEditModal">
      <view class="edit-modal" catchtap="stopPropagation">
        <view class="edit-header">
          <text class="edit-title">修改识别结果</text>
        </view>
        <view class="edit-body">
          <input
            class="edit-input"
            placeholder="请输入正确的菜名"
            value="{{editDishName}}"
            bindinput="onEditInput"
          />
        </view>
        <view class="edit-btns">
          <button class="edit-btn-cancel" bindtap="closeEditModal">取消</button>
          <button class="edit-btn-confirm" bindtap="confirmEdit">确认</button>
        </view>
      </view>
    </view>

    <!-- 分析中状态 -->
    <view class="analyze-loading" wx:if="{{analyzing}}">
      <view class="loading-robot">🤖</view>
      <view class="loading-title">AI 营养师正在看图分析…</view>
      <view class="loading-steps-mini">
        <view class="mini-step {{loadingStep >= 1 ? 'done' : ''}}">
          <view class="mini-dot"></view><text>识别图片内容</text>
        </view>
        <view class="mini-step {{loadingStep >= 2 ? 'done' : ''}}">
          <view class="mini-dot"></view><text>判断食材类型</text>
        </view>
        <view class="mini-step {{loadingStep >= 3 ? 'done' : ''}}">
          <view class="mini-dot"></view><text>评估肾友安全</text>
        </view>
        <view class="mini-step {{loadingStep >= 4 ? 'done' : ''}}">
          <view class="mini-dot"></view><text>生成分析报告</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ════════════════ 类型选择（未分析时显示）════════════════ -->
  <view class="type-select-section" wx:if="{{!analyzing && !result}}">
    <view class="type-title">这是什么？</view>
    <view class="type-grid">
      <view
        class="type-card {{selectedType === item.key ? 'selected' : ''}}"
        wx:for="{{imageTypes}}"
        wx:key="key"
        bindtap="selectType"
        data-type="{{item.key}}"
      >
        <view class="type-icon">{{item.icon}}</view>
        <view class="type-name">{{item.name}}</view>
        <view class="type-desc">{{item.desc}}</view>
      </view>
    </view>
    <!-- 开始分析按钮 -->
    <button
      class="start-analyze-btn {{!selectedType || analyzing ? 'disabled' : ''}}"
      bindtap="startAnalyze"
      disabled="{{!selectedType || analyzing}}"
    >
      开始智能分析
    </button>
  </view>

  <!-- ════════════════ 分析结果（复用 detail 页的展示结构）════════════════ -->
  <block wx:if="{{!analyzing && result}}">

    <!-- 安全等级 Banner -->
    <view class="safe-banner" style="background:{{result.levelCfg.gradient}}">
      <view class="banner-left">
        <view class="banner-icon">{{result.levelCfg.icon}}</view>
        <view class="banner-info">
          <view class="banner-dish">{{result.dishName}}</view>
          <view class="banner-label">{{result.levelCfg.label}}</view>
          <view class="banner-stage">{{stageName}}</view>
        </view>
      </view>
      <view class="score-circle" style="border-color:rgba(255,255,255,0.6)">
        <view class="score-num">{{result.score}}</view>
        <view class="score-unit">分</view>
        <view class="score-label">肾友评分</view>
      </view>
    </view>

    <!-- 来源标签 -->
    <view class="source-tag">
      <text class="source-text">📷 AI 看图分析 · {{_typeLabel}}</text>
    </view>

    <!-- 图片类型警告区（重点！）-->
    <view class="cook-warning-card card" wx:if="{{result._cookWarning}}">
      <view class="cook-warning-header">
        <text class="cook-warning-icon">⚠️</text>
        <text class="cook-warning-title">烹饪方式警告</text>
      </view>
      <view class="cook-warning-text">{{result._cookWarning}}</view>
    </view>

    <!-- 安全说明卡 -->
    <view class="card">
      <view class="card-title">
        <text class="card-title-icon">🛡️</text>
        <text>安全分析</text>
      </view>
      <view class="reason-text">{{result.reason}}</view>

      <!-- 关键风险警告 -->
      <view class="warnings-wrap" wx:if="{{result.keyWarnings && result.keyWarnings.length > 0}}">
        <view class="warning-item" wx:for="{{result.keyWarnings}}" wx:key="*this">
          <text class="warning-icon">⚡</text>
          <text class="warning-text">{{item}}</text>
        </view>
      </view>

      <!-- 烹饪方式推荐/禁止 -->
      <view class="cook-method-wrap" wx:if="{{result.cookMethodDisplay}}">
        <view class="cook-method-row" wx:if="{{result.cookMethodDisplay.recommended && result.cookMethodDisplay.recommended.length > 0}}">
          <text class="cook-method-label recommend">✅ 推荐方式</text>
          <view class="cook-tags">
            <view class="cook-tag recommend" wx:for="{{result.cookMethodDisplay.recommended}}" wx:key="name">
              {{item.icon}} {{item.name}}
            </view>
          </view>
        </view>
        <view class="cook-method-row" wx:if="{{result.cookMethodDisplay.avoid && result.cookMethodDisplay.avoid.length > 0}}">
          <text class="cook-method-label avoid">🚫 避免方式</text>
          <view class="cook-tags">
            <view class="cook-tag avoid" wx:for="{{result.cookMethodDisplay.avoid}}" wx:key="name">
              {{item.icon}} {{item.name}}
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 食材安全评级 -->
    <view class="card" wx:if="{{result.ingredients && result.ingredients.length > 0}}">
      <view class="card-title" bindtap="toggleIngredients">
        <view class="card-title-left">
          <text class="card-title-icon">🥬</text>
          <text>食材安全评级</text>
          <text class="card-count">共{{result.ingredients.length}}种</text>
        </view>
        <text class="card-expand-icon">{{ingredientsExpanded ? '▲' : '▼'}}</text>
      </view>
      <view wx:if="{{ingredientsExpanded}}">
        <view class="ing-item" wx:for="{{result.ingredients}}" wx:key="name">
          <view class="ing-left">
            <text class="ing-cat-icon">{{item.categoryIcon}}</text>
            <view class="ing-info">
              <view class="ing-name-row">
                <text class="ing-name">{{item.name}}</text>
                <text class="ing-amount text-sm text-secondary"> / {{item.amount}}</text>
              </view>
              <text class="ing-tip text-sm">{{item.tip}}</text>
              <view class="ing-risk" wx:if="{{item.risk}}">
                <text class="risk-tag">⚠ {{item.risk}}</text>
              </view>
            </view>
          </view>
          <view class="ing-badge" style="background:{{item.safeColor}}">
            <text class="ing-badge-text">{{item.safeLabel}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 营养分析 -->
    <view class="card" wx:if="{{result.nutritionBars}}">
      <view class="card-title" bindtap="toggleNutrition">
        <view class="card-title-left">
          <text class="card-title-icon">📊</text>
          <text>营养分析</text>
          <text class="card-sub text-sm text-secondary"> 每份约{{result.servingSize}}</text>
        </view>
        <text class="card-expand-icon">{{nutritionExpanded ? '▲' : '▼'}}</text>
      </view>
      <view wx:if="{{nutritionExpanded}}">
        <view class="nut-bar-item" wx:for="{{result.nutritionBars}}" wx:key="key">
          <view class="nut-bar-header">
            <view class="nut-bar-label">
              <text class="nut-bar-icon">{{item.icon}}</text>
              <text class="nut-bar-name">{{item.label}}</text>
              <text class="nut-bar-value" style="color:{{item.evalColor}}">{{item.value}} {{item.unit}}</text>
            </view>
            <view class="nut-eval-badge" style="background:{{item.evalColor}}">
              <text class="nut-eval-text">{{item.eval}}</text>
            </view>
          </view>
          <view class="nut-bar-track">
            <view class="nut-bar-fill" style="width:{{item.percent}}%;background:{{item.barColor}}"></view>
          </view>
          <view class="nut-bar-footer">
            <text class="nut-bar-percent text-sm text-secondary">占每日参考量 {{item.percent}}%</text>
            <text class="nut-bar-daily text-sm text-secondary">参考总量：{{item.dailyRef}} {{item.unit}}</text>
          </view>
        </view>
        <view class="nut-tips-box" wx:if="{{result.nutritionTips}}">
          <text class="nut-tips-icon">💡</text>
          <text class="nut-tips-text">{{result.nutritionTips}}</text>
        </view>
      </view>
    </view>

    <!-- 肾友版做法步骤 -->
    <view class="card" wx:if="{{result.steps && result.steps.length > 0}}">
      <view class="card-title" bindtap="toggleSteps">
        <view class="card-title-left">
          <text class="card-title-icon">👨‍🍳</text>
          <text>肾友版做法</text>
          <text class="card-count">{{result.steps.length}}步</text>
        </view>
        <text class="card-expand-icon">{{stepsExpanded ? '▲' : '▼'}}</text>
      </view>
      <view wx:if="{{stepsExpanded}}">
        <view class="step-card" wx:for="{{result.steps}}" wx:key="stepNo">
          <view class="step-head">
            <view class="step-num-badge">{{item.stepNo}}</view>
            <text class="step-title">{{item.title}}</text>
          </view>
          <view class="step-detail">{{item.detail}}</view>
          <view class="step-kidney-care" wx:if="{{item.kidneyCare}}">
            <text class="kidney-icon">🫘</text>
            <text class="kidney-text">{{item.kidneyCare}}</text>
          </view>
        </view>
        <view class="cook-tips-box" wx:if="{{result.cookTips}}">
          <view class="cook-tips-title">💡 综合烹饪贴士</view>
          <view class="cook-tips-text">{{result.cookTips}}</view>
        </view>
      </view>
    </view>

    <!-- 更优替代推荐 -->
    <view class="card" wx:if="{{result.alternatives && result.alternatives.length > 0}}">
      <view class="card-title">
        <text class="card-title-icon">🥗</text>
        <text>更优选择推荐</text>
      </view>
      <view class="alt-item" wx:for="{{result.alternatives}}" wx:key="name" bindtap="viewAlternative" data-name="{{item.name}}">
        <view class="alt-score-circle" style="border-color:{{item.scoreColor}}">
          <text class="alt-score-num" style="color:{{item.scoreColor}}">{{item.score}}</text>
        </view>
        <view class="alt-info">
          <view class="alt-name-row">
            <text class="alt-name">{{item.name}}</text>
            <text class="alt-safe-icon">{{item.safeLevelIcon}}</text>
          </view>
          <text class="alt-reason text-sm text-secondary">{{item.reason}}</text>
        </view>
        <text class="alt-arrow">›</text>
      </view>
    </view>

    <!-- 医疗免责声明 -->
    <view class="medical-note" wx:if="{{result.medicalNote}}">
      <text class="medical-icon">⚕️</text>
      <text class="medical-text">{{result.medicalNote}}</text>
    </view>

    <!-- 底部操作按钮 -->
    <view class="action-bar">
      <button class="btn-outline" bindtap="toggleFavorite">
        <text>{{isFavorited ? '❤️' : '🤍'}}</text>
        <text> {{isFavorited ? '已收藏' : '收藏'}}</text>
      </button>
      <button class="btn-primary" bindtap="addToRecord">
        <text>📝 记录饮食</text>
      </button>
    </view>

  </block>

  <!-- ════════════════ 错误状态 ════════════════ -->
  <view class="error-card" wx:if="{{!analyzing && error}}">
    <view class="error-icon">{{_quotaExceeded ? '🔒' : '😔'}}</view>
    <view class="error-title">{{_quotaExceeded ? '今日分析次数已用完' : '分析失败'}}</view>
    <view class="error-msg">{{error}}</view>
    <view wx:if="{{_quotaExceeded}}" class="quota-actions">
      <button class="btn-vip" bindtap="goVip">🌿 加入会员 ¥9.9/月</button>
    </view>
    <button class="retry-btn" bindtap="retryAnalyze" wx:if="{{!_quotaExceeded}}">重新分析</button>
    <button class="retry-btn btn-vip" bindtap="goVip" wx:if="{{_quotaExceeded}}">🌿 加入会员解锁</button>
  </view>
  <view class="portion-modal-mask" wx:if="{{showPortionModal}}" bindtap="closePortionModal">
    <view class="portion-modal">
      <view class="portion-header">
        <text class="portion-title">📝 记录饮食</text>
        <text class="portion-dish">{{result.dishName}}</text>
      </view>

      <view class="portion-scroll">
        <!-- 餐段选择 -->
        <view class="meal-select-row">
          <text class="meal-select-label">选择餐段</text>
          <view class="meal-select">
            <view
              class="meal-option {{selectedMealType === item.value ? 'active' : ''}}"
              wx:for="{{mealOptions}}"
              wx:key="value"
              catchtap="selectMealType"
              data-value="{{item.value}}"
            >
              <text class="meal-icon">{{item.icon}}</text>
              <text>{{item.label}}</text>
            </view>
          </view>
        </view>

        <view class="portion-slider-row">
          <view class="portion-slider-label">
            <text class="portion-slider-name">本次摄入量</text>
            <text class="portion-slider-val">{{portionGrams}}g</text>
          </view>
          <slider
            class="portion-slider"
            min="{{portionMin}}"
            max="{{portionMax}}"
            step="{{portionStep}}"
            value="{{portionGrams}}"
            activeColor="#52C41A"
            backgroundColor="#E8E8E8"
            block-size="20"
            bindchange="onPortionChange"
            bindchanging="onPortionChanging"
          />
          <view class="portion-slider-range">
            <text>{{portionMin}}g</text>
            <text>{{portionMax}}g</text>
          </view>
        </view>

        <view class="portion-nut-list">
          <view class="portion-nut-item" wx:for="{{portionNutrients}}" wx:key="key">
            <view class="portion-nut-left">
              <text class="portion-nut-icon">{{item.icon}}</text>
              <text class="portion-nut-name">{{item.label}}</text>
            </view>
            <view class="portion-nut-right">
              <text class="portion-nut-val" style="color:{{item.color}}">{{item.value}} {{item.unit}}</text>
              <text class="portion-nut-ratio">≈ {{item.percent}}% 每日参考量</text>
            </view>
          </view>
        </view>
      </view>

      <view class="portion-btns">
        <button class="portion-btn-cancel" catchtap="closePortionModal">取消</button>
        <button class="portion-btn-confirm" catchtap="confirmRecord">确认记录</button>
      </view>
    </view>
  </view>

</view>
