/* pages/recipes/category/index.wxss - 菜谱库样式 */
page {
  background: var(--bg, #F5F7FA);
}

.page-wrap {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

/* ═══ 搜索栏 ═══ */
.search-bar {
  background: #fff;
  padding: 20rpx 28rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.05);
}

.search-box {
  display: flex;
  align-items: center;
  background: var(--bg, #F5F7FA);
  border-radius: 100rpx;
  padding: 18rpx 28rpx;
  gap: 12rpx;
}

.search-icon { font-size: 28rpx; opacity: 0.5; flex-shrink: 0; }

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary, #333);
  height: 44rpx;
}

.search-placeholder { color: #BFBFBF; font-size: 28rpx; }

.search-clear {
  font-size: 24rpx;
  color: var(--text-light, #999);
  padding: 8rpx;
}

/* ═══ 分类 Tab ═══ */
.category-tabs {
  background: #fff;
  white-space: nowrap;
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.05);
}

.cat-tab {
  display: inline-block;
  font-size: 26rpx;
  color: var(--text-secondary, #666);
  padding: 10rpx 28rpx;
  border-radius: 100rpx;
  margin-right: 12rpx;
  background: var(--bg, #F5F7FA);
  transition: all 0.2s;
}

.cat-tab.active {
  background: var(--primary, #4A90D9);
  color: #fff;
  font-weight: 600;
}

/* ═══ 筛选信息栏 ═══ */
.filter-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 28rpx;
  background: #fff;
  border-bottom: 1rpx solid rgba(0,0,0,0.05);
}

.filter-info {
  font-size: 22rpx;
  color: var(--text-light, #999);
}

.level-filters {
  white-space: nowrap;
  max-width: 60%;
}

.level-chip {
  display: inline-block;
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: 100rpx;
  margin-right: 8rpx;
  color: var(--text-secondary, #666);
  background: var(--bg, #F5F7FA);
  border: 1rpx solid transparent;
}

.level-chip.active {
  font-weight: 600;
  border-color: currentColor;
}

.level-chip[data-level="safe"].active { color: #52C41A; background: #F0FFF4; }
.level-chip[data-level="warning"].active { color: #FAAD14; background: #FFFBF0; }
.level-chip[data-level="danger"].active { color: #E74C3C; background: #FFF2F0; }

/* ═══ 列表区域 ═══ */
.recipe-list {
  flex: 1;
  padding: 16rpx 28rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 16rpx;
  font-size: 28rpx;
  color: var(--text-secondary, #666);
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--border, #E8E8E8);
  border-top-color: var(--primary, #4A90D9);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  gap: 12rpx;
}

.empty-icon { font-size: 80rpx; }
.empty-text { font-size: 30rpx; color: var(--text-secondary, #666); }
.empty-hint { font-size: 24rpx; color: var(--text-light, #999); }

/* ═══ 菜谱卡片 ═══ */
.recipe-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.recipe-card:active {
  transform: scale(0.985);
  transition: transform 0.1s;
}

.recipe-card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.recipe-name-area {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.recipe-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary, #333);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recipe-cat-tag {
  font-size: 20rpx;
  color: var(--primary, #4A90D9);
  background: var(--primary-light, rgba(74,144,217,0.1));
  padding: 4rpx 14rpx;
  border-radius: 100rpx;
  flex-shrink: 0;
}

/* 安全等级标签 */
.safe-badge {
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 18rpx;
  border-radius: 100rpx;
  flex-shrink: 0;
}

.safe-safe { background: #F0FFF4; color: #52C41A; }
.safe-warning { background: #FFFBF0; color: #FAAD14; }
.safe-danger { background: #FFF2F0; color: #E74C3C; }

/* 描述 */
.recipe-desc {
  font-size: 26rpx;
  color: var(--text-secondary, #666);
  line-height: 1.6;
  margin-bottom: 16rpx;
}

/* 营养数据网格 */
.nut-grid {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  overflow-x: auto;
  white-space: nowrap;
  padding-bottom: 4rpx;
  margin-bottom: 12rpx;
}

.nut-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 100rpx;
  padding: 14rpx 12rpx;
  background: var(--bg, #F5F7FA);
  border-radius: 12rpx;
}

.nut-cell-val {
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.2;
}

.nut-cell-unit {
  font-size: 18rpx;
  color: var(--text-light, #999);
  margin-top: 2rpx;
}

.nut-cell-label {
  font-size: 20rpx;
  color: var(--text-secondary, #666);
  margin-top: 4rpx;
}

/* 标签行 */
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed var(--border, #EEE);
}

.mini-tag {
  font-size: 20rpx;
  color: var(--text-light, #999);
  background: var(--bg, #F5F7FA);
  padding: 4rpx 14rpx;
  border-radius: 100rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 24rpx 0;
}

.load-more-text {
  font-size: 24rpx;
  color: var(--text-light, #999);
}

.load-more-done {
  font-size: 22rpx;
  color: var(--border, #DDD);
}
