<!-- pages/empty/index.wxml - 空白页面，用于根据后端配置跳转 -->
<view class="container">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-section">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在获取配置...</text>
  </view>

  <!-- 错误状态 -->
  <view wx:if="{{!loading && error}}" class="error-section">
    <text class="error-icon">⚠️</text>
    <text class="error-text">{{error}}</text>
    <button class="retry-btn" bindtap="retry">重试</button>
  </view>

  <!-- 正常加载完成（短暂显示） -->
  <!-- <view wx:if="{{!loading && !error}}" class="redirect-section">
    <text class="redirect-text">正在进入...</text>
    <text class="hint-text">请稍候</text>
  </view> -->
</view>