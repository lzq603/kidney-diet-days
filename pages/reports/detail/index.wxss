/* pages/reports/detail/index.wxss */
.page { padding: 28rpx; min-height: 100vh; background: #F5F7FA; }

.loading-tip { text-align: center; padding: 100rpx; font-size: 28rpx; color: #BDC3C7; }

.report-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.report-date { font-size: 30rpx; font-weight: 700; color: #2C3E50; }
.report-source { font-size: 22rpx; color: #BDC3C7; }

.indicator-list { background: #fff; border-radius: 24rpx; padding: 8rpx 0; margin-bottom: 32rpx; }
.indicator-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 24rpx 28rpx; border-bottom: 1rpx solid #F0F4F8;
}
.indicator-item:last-child { border-bottom: none; }
.indicator-label { font-size: 28rpx; font-weight: 600; color: #2C3E50; display: block; }
.indicator-ref { font-size: 22rpx; color: #BDC3C7; display: block; margin-top: 4rpx; }
.indicator-right { text-align: right; }
.indicator-value { font-size: 36rpx; font-weight: 800; color: #2C3E50; }
.indicator-unit { font-size: 22rpx; color: #7F8C8D; margin-left: 4rpx; }
.indicator-eval { display: block; font-size: 22rpx; margin-top: 4rpx; }

.empty-tip { text-align: center; padding: 80rpx; font-size: 26rpx; color: #BDC3C7; background: #fff; border-radius: 24rpx; }

.delete-btn {
  width: 100%; height: 80rpx; line-height: 80rpx;
  background: #fff; color: #FF4D4F; font-size: 28rpx;
  border-radius: 40rpx; border: 2rpx solid #FFE0DF;
  text-align: center; margin-bottom: 40rpx;
}
