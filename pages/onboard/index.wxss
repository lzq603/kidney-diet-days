/* pages/index/index.wxss - 引导页样式 */
page {
  background: #FFFFFF;
}

.splash-wrap {
  min-height: 100vh;
  padding: 80rpx 48rpx 60rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* 背景装饰圆 */
.bg-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.08;
  background: var(--primary);
}

.bg-circle-1 {
  width: 500rpx;
  height: 500rpx;
  top: -150rpx;
  right: -150rpx;
}

.bg-circle-2 {
  width: 300rpx;
  height: 300rpx;
  top: 200rpx;
  left: -100rpx;
}

.bg-circle-3 {
  width: 200rpx;
  height: 200rpx;
  bottom: 200rpx;
  right: -60rpx;
}

/* Logo区域 */
.logo-area {
  text-align: center;
  padding: 60rpx 0 48rpx;
  flex-shrink: 0;
}

.logo-icon {
  font-size: 120rpx;
  line-height: 1;
  margin-bottom: 24rpx;
  filter: drop-shadow(0 8rpx 16rpx rgba(74,144,217,0.3));
}

.app-name {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--primary);
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: var(--text-secondary);
  letter-spacing: 2rpx;
}

/* 特性列表 */
.features {
  margin: 20rpx 0 36rpx;
  flex-shrink: 0;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: var(--primary-light);
  border-radius: var(--radius);
  margin-bottom: 16rpx;
}

.feature-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.feature-info {
  flex: 1;
}

.feature-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 分期选择 */
.stage-section {
  margin-bottom: 32rpx;
  flex-shrink: 0;
}

.stage-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 24rpx;
}

.stage-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.stage-item {
  background: #F8F9FA;
  border-radius: var(--radius);
  padding: 20rpx 12rpx;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.stage-item.active {
  background: var(--primary-light);
  border-color: var(--primary);
}

.stage-label {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.stage-item.active .stage-label {
  color: var(--primary);
}

.stage-desc {
  font-size: 20rpx;
  color: var(--text-secondary);
}

.stage-tip {
  font-size: 22rpx;
  color: var(--text-secondary);
  text-align: center;
  background: var(--warning-light);
  padding: 16rpx 24rpx;
  border-radius: var(--radius-sm);
}

/* 操作区 */
.action-area {
  margin-top: auto;
  padding-top: 24rpx;
  flex-shrink: 0;
}

.start-btn {
  background: var(--primary) !important;
  color: #fff !important;
  border-radius: 100rpx !important;
  height: 96rpx !important;
  line-height: normal !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  font-size: 34rpx !important;
  font-weight: 700 !important;
  box-shadow: 0 8rpx 24rpx rgba(74,144,217,0.4) !important;
  border: none !important;
  padding: 0 !important;
  margin-bottom: 24rpx;
}

.disclaimer {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-light);
}
