/* app.wxss - 全局样式 */

/* CSS 变量 */
page {
  --primary: #4A90D9;
  --primary-light: #EAF3FD;
  --primary-dark: #2E6DB4;
  --success: #52C41A;
  --success-light: #F6FFED;
  --warning: #FAAD14;
  --warning-light: #FFFBE6;
  --danger: #FF4D4F;
  --danger-light: #FFF1F0;
  --text-primary: #2C3E50;
  --text-secondary: #7F8C8D;
  --text-light: #BDC3C7;
  --border: #E8ECF0;
  --bg: #F5F7FA;
  --bg-white: #FFFFFF;
  --radius-sm: 8rpx;
  --radius: 16rpx;
  --radius-lg: 24rpx;
  --shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  --shadow-card: 0 2rpx 12rpx rgba(0,0,0,0.06);

  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  background-color: var(--bg);
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.6;
}

/* 通用容器 */
.container {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 卡片 */
.card {
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

/* 按钮 */
.btn-primary {
  background: var(--primary);
  color: #fff;
  border-radius: var(--radius);
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  border: none;
  width: 100%;
  box-sizing: border-box;
}

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: var(--radius);
  padding: 22rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  width: 100%;
  box-sizing: border-box;
}

/* 标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  display: inline-block;
  width: 6rpx;
  height: 36rpx;
  background: var(--primary);
  border-radius: 3rpx;
  margin-right: 16rpx;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.tag-safe {
  background: var(--success-light);
  color: var(--success);
}

.tag-warning {
  background: var(--warning-light);
  color: var(--warning);
}

.tag-danger {
  background: var(--danger-light);
  color: var(--danger);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 24rpx 0;
}

/* flex 工具类 */
.flex {
  display: flex;
  align-items: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

/* 文字工具类 */
.text-primary { color: var(--primary); }
.text-success { color: var(--success); }
.text-warning { color: var(--warning); }
.text-danger { color: var(--danger); }
.text-secondary { color: var(--text-secondary); }
.text-sm { font-size: 24rpx; }
.text-lg { font-size: 34rpx; }
.text-xl { font-size: 40rpx; }
.font-bold { font-weight: 700; }

/* 加载状态 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-text {
  color: var(--text-secondary);
  font-size: 26rpx;
  margin-top: 16rpx;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  color: var(--text-secondary);
  font-size: 28rpx;
}
